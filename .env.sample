# Required. Cloud API key or Engine bearer token.
FLOYD_API_KEY=floyd_live_xxx

# Optional. Default: https://api.floyd.run/v1
# Cloud:       https://api.floyd.run/v1
# Self-hosted: https://myengine.com/v1/ledgers/ldg_xxx
FLOYD_BASE_URL=https://api.floyd.run/v1

# Optional. Default: 3000. Streamable HTTP listen port.
PORT=3000
