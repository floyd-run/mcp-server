{
  "name": "@floyd-run/mcp-server",
  "version": "0.1.0",
  "description": "Floyd MCP Server — booking and scheduling tools for AI agents",
  "type": "module",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsx src/index.ts",
    "format": "prettier --write .",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "hono": "^4.7.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.28.0",
    "prettier": "^3.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.53.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
